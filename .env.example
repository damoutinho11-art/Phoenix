ANTHROPIC_API_KEY=
# Optional AI gateway mode:
# PHOENIX_AI_PROVIDER=anthropic | freellmapi | auto | off
PHOENIX_AI_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
PHOENIX_LLM_BASE_URL=http://localhost:3001/v1
PHOENIX_LLM_API_KEY=
PHOENIX_LLM_MODEL=auto
PHOENIX_LLM_TIMEOUT_SECONDS=45
PHOENIX_NEWS_ENABLED=true
PHOENIX_NEWS_CACHE_SECONDS=900
PHOENIX_CALENDAR_FEED_TOKEN=
PHOENIX_PUBLIC_BASE_URL=
# Google Calendar + Gmail read-only OAuth connectors (see docs/google-gmail-setup.md)
PHOENIX_GOOGLE_CLIENT_ID=
PHOENIX_GOOGLE_CLIENT_SECRET=
PHOENIX_GOOGLE_REDIRECT_URI=
PHOENIX_TOKEN_ENCRYPTION_KEY=
PHOENIX_GMAIL_DEFAULT_QUERY=
PHOENIX_PUBLIC_FRONTEND_URL=
